# ====================================================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE — AGIL.AI
# Copie este arquivo para .env e preencha com seus valores reais:
#   copy .env.example .env
# ====================================================================

# --- 1. MICROSSERVIÇOS LOCAIS (OLLAMA, TTS & STT) ---

OLLAMA_API_URL=http://host.docker.internal:11434/api/generate
TTS_API_URL=http://kokoro:8000/synthesize
WHISPER_API_URL=http://whisper-stt:9000/transcribe

# --- 2. CONFIGURAÇÕES DE COMUNICAÇÃO E ADMIN ---

EMAIL_ADMIN_ALERTA=seu-email@exemplo.com
WHATSAPP_DEST_NUMBER=+55XXXXXXXXXXX

# --- 3. GOOGLE CLOUD STORAGE ---

GCS_BUCKET_NAME=nome-do-seu-bucket

# --- 4. GOOGLE SHEETS (LOG CRÍTICO) ---

# ID da planilha (URL: .../spreadsheets/d/ESTE_ID/edit)
GOOGLE_SHEETS_LOG_ID=COLE_O_ID_DA_PLANILHA_AQUI

GOOGLE_SHEETS_API_URL=https://sheets.googleapis.com/v4/spreadsheets
GOOGLE_SHEETS_SHEET_NAME=NomeDaAba

# --- 5. N8N ---

N8N_HOST=localhost
N8N_PORT=5678
GENERIC_TIMEZONE=America/Sao_Paulo

# ====================================================================
# NÃO coloque aqui tokens de API (Twilio, Google OAuth, Trello, etc.).
# Essas credenciais são configuradas na interface do n8n e ficam
# criptografadas em data/database.sqlite (protegida pelo .gitignore).
#
# WEBHOOK TWILIO: após importar n8n-ia-workflow.example.json no n8n,
# gere um novo path no nó Webhook e atualize a URL no painel Twilio.
# ====================================================================
