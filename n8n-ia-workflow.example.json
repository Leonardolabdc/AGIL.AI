    {
      "parameters": {
        "jsCode": "// NÓ CODE: FORMATA TEXTO PARA ÁUDIO\n// Objetivo: Limpar a mensagem, **ESCAPAR ASPAS** e propagar contexto.\n\nfor (const item of items) {\n  \n  // 1. EXTRAÇÃO DE VARIÁVEIS DE CONTEXTO ESTÁVEIS\n  let responseText = $('Contexto Ollama').item.json.original_message;\n  let phoneNumber = $('Contexto Ollama').item.json.phone_number;\n  let caminhoOllama = $('Limpeza Ollama').item.json.caminho_ollama;\n\n  // 2. LIMPEZA DA MENSAGEM\n  \n  // Remove emojis\n  const emojiRegex = /(\\u00a9|\\u00ae|[\\u2000-\\u3300]|\\ud83c[\\ud000-\\udfff]|\\ud83d[\\ud000-\\udfff]|\\ud83e[\\ud000-\\udfff])/g;\n  responseText = responseText.replace(emojiRegex, '');\n\n  // Remove quebras de linha e múltiplos espaços\n  responseText = responseText.replace(/\\n/g, ' ').replace(/\\s{2,}/g, ' ').trim();\n  \n  // *** CORREÇÃO CRÍTICA: ESCAPE DE ASPAS DUPLAS ***\n  // Escapa todas as aspas duplas internas (\") para que o JSON do TTS não quebre.\n  responseText = responseText.replace(/\"/g, '\\\\\"');\n  \n  // 3. PROPAGAÇÃO DAS VARIÁVEIS\n  \n  // CRÍTICO: 'Whatsapp-Message' agora contém o texto limpo E escapado\n  item.json['Whatsapp-Message'] = responseText; \n  \n  item.json.Telefone_Usuario = phoneNumber;\n  item.json.caminho_ollama = caminhoOllama;\n}\n\n// Retorna todos os itens modificados.\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -400,
        192
      ],
      "id": "15a3c530-d812-4c2f-b165-415d3921580e",
      "name": "Formata Texto para Áudio"
    },
    {
      "parameters": {
        "jsCode": "// NÓ CODE: LIMPEZA OLLAMA (Com Prioridade Máxima para WHATSAPP)\n\nfor (const item of items) {\n    // 1. EXTRAÇÃO DAS VARIÁVEIS DE CONTEXTO\n    const originalMessage = $('Contexto Ollama').item.json.original_message;\n    const phoneNumber = $('Contexto Ollama').item.json.phone_number;\n    \n    const ollamaResponseBruta = item.json.response;\n\n    let caminho = 'erro'; // Valor padrão inicial\n    \n    // 2. EXTRAÇÃO E LIMPEZA DA RESPOSTA BRUTA (Parsing da IA)\n    const regex = /```json\\s*(\\{[\\s\\S]*?\\})\\s*```/;\n    const match = ollamaResponseBruta.match(regex);\n    \n    if (match && match[1]) {\n        const jsonStringLimpa = match[1].trim();\n        try {\n            const parsedJson = JSON.parse(jsonStringLimpa);\n            if (parsedJson && parsedJson.caminho) {\n                // Pega a decisão do Ollama, que será verificada abaixo\n                caminho = parsedJson.caminho;\n            }\n        } catch (e) {\n            console.error(\"Falha ao analisar JSON de roteamento:\", e, \"String recebida:\", jsonStringLimpa);\n        }\n    }\n\n\n    // *** 3. LÓGICA DE OVERRIDE COM PRIORIDADE (AQUI ESTÁ A CORREÇÃO FINAL) ***\n    const originalMessageLower = originalMessage.toLowerCase();\n\n    // A. PRIORITY 1: WHATSAPP (Urgency overrides everything, including Trello)\n    if (originalMessageLower.includes('agora') || \n        originalMessageLower.includes('urgente') ||\n        originalMessageLower.includes('ligue') ||\n        originalMessageLower.includes('retorna') ||\n        originalMessageLower.includes('imediatamente')) \n    {\n        caminho = 'whats'; // FORÇA A ROTA WHATSAPP (PRIORIDADE MÁXIMA)\n    } \n    \n    // B. PRIORITY 2: TRELLO (Executa APENAS se o caminho ainda não for 'whats' e for de organização)\n    else if (originalMessageLower.includes('card') || originalMessageLower.includes('organizar') ||\n             originalMessageLower.includes('pendências') || originalMessageLower.includes('checklist') ||\n             originalMessageLower.includes('trello')) \n    {\n        caminho = 'trello'; // Força a rota Trello\n    } \n\n\n    // 4. LÓGICA DE ALERTA/FALLBACK (Segurança Final)\n    const caminhosValidos = ['email', 'whats', 'trello'];\n    \n    // Se o caminho não é um dos 3 válidos (e não foi forçado acima), é um ALERTA_FALHA\n    if (!caminhosValidos.includes(caminho)) {\n        caminho = 'ALERTA_FALHA'; \n    }\n    \n    \n    // 5. CONSOLIDA AS VARIÁVEIS NA SAÍDA\n    item.json.caminho_ollama = caminho; \n    item.json['Whatsapp-Message'] = originalMessage; \n    item.json.Telefone_Usuario = phoneNumber;\n}\n\nreturn items;"
      },
