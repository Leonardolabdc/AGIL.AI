    {
      "parameters": {
        "jsCode": "// NÓ CODE: FORMATA ÁUDIO\n// Este nó prepara o nome do arquivo para o Google Storage (Upload)\n// e puxa as variáveis de contexto que são necessárias depois.\n\nfor (const item of items) {\n  // 1. GERAÇÃO DO NOME DO ARQUIVO\n  // Cria um nome de arquivo único usando o timestamp para evitar colisões\n  const timestamp = new Date().getTime();\n  const filename = `${timestamp}.mp3`;\n\n  // Adiciona a variável 'filename' ao objeto JSON do item.\n  // O nó 'Upload Google Storage' usará essa variável.\n  item.json.filename = filename;\n\n  // 2. EXTRAÇÃO DE VARIÁVEIS DE CONTEXTO\n  // Puxa o telefone e a mensagem do nó 'Contexto Ollama' (o nó Code no início do fluxo)\n  // Nota: Isso é necessário porque o nó 'Filtro Ollama' pode não ter sido executado ainda\n  // ou pode estar em uma branch separada.\n  \n  // Puxa o telefone limpo (Ex: +55419...)\n  item.json.Telefone_Usuario = $('Contexto Ollama').item.json.phone_number;\n\n  // Puxa a mensagem original\n  item.json['Whatsapp-Message'] = $('Contexto Ollama').item.json.original_message;\n  \n  // (Nenhuma modificação é feita nos dados binários do áudio, eles são passados adiante.)\n}\n\n// Retorna todos os itens modificados.\nreturn items;\n"
      },
